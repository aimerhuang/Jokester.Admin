ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:5049

Jwt__Issuer=
Jwt__Audience=
Jwt__SecretKey=
Jwt__AccessTokenExpiresMinutes=120
Jwt__RefreshTokenExpiresDays=7

Database__Provider=MySql
Database__ConnectionString=server=<db-host>;Database=jokester.admin;Uid=<db-user>;Pwd=<db-password>;Port=3306;Allow User Variables=True;SslMode=None;AllowPublicKeyRetrieval=True;

Redis__ConnectionString=<redis-host>:6379,abortConnect=false
Redis__InstanceName=jokester-admin
Redis__EnableInMemoryRefreshTokenFallback=false

Mail__Host=smtp.163.com
Mail__Port=587
Mail__UseSsl=false
Mail__SecureSocketOptions=StartTls
Mail__UserName=
Mail__Password=
Mail__FromAddress=
Mail__FromName=Jokester

EmailValidation__EnableApiValidation=false
EmailValidation__ApiEndpoint=
EmailValidation__ApiKey=
EmailValidation__ApiKeyHeaderName=Authorization

OpenAI__BaseUrl=https://api.openai.com/v1
OpenAI__ApiKey=
OpenAI__ImageModel=gpt-image-2

NanoBanana2__BaseUrl=
NanoBanana2__ApiKey=
NanoBanana2__ImageModel=nano-banana-2
NanoBanana2__TextToImagePath=/images/generations
NanoBanana2__ImageToImagePath=/images/edits

BootstrapAdmin__UserName=
BootstrapAdmin__Password=
BootstrapAdmin__Secret=
